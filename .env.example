# Переменные окружения для проекта.
# Скопируй в .env и подставь реальные значения.

# --- Neo4j (заполняется автоматически из docker-compose.yml) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=knowledge
NEO4J_BATCH_SIZE=500

# --- Yandex Foundation Models (YandexGPT и DeepSeek) ---
# API-ключ: https://console.yandex.cloud/ → IAM → API-ключи
# Folder ID: https://console.yandex.cloud/ → ваш облачный каталог
YANDEX_GPT_API_KEY=your_api_key_here
YANDEX_GPT_FOLDER_ID=your_folder_id_here
# Для режима `real`: yandexgpt-lite, yandexgpt, yandexgpt-32k, qwen2-72b-instruct и т.п.
# Для режима `deepseek`: Model Gallery через Yandex AI Studio OpenAI-compatible API.
#   Используйте полный gpt:// URI или имя модели из DEEPSEEK_MODEL.
YANDEX_GPT_MODEL_URI=yandexgpt-lite

# --- DeepSeek (хостится на Yandex Cloud / Yandex AI Studio) ---
# DeepSeek здесь НЕ вызывается через api.deepseek.com и не требует отдельного
# DeepSeek-ключа. Он использует YANDEX_GPT_API_KEY и endpoint
# https://ai.api.cloud.yandex.net/v1/chat/completions.
DEEPSEEK_MODEL=deepseek-v4-flash/latest
YANDEX_OPENAI_BASE_URL=https://ai.api.cloud.yandex.net/v1
YANDEX_REASONING_EFFORT=none

# --- OpenRouter ---
# Free models on OpenRouter usually have a ":free" suffix. The default below
# was selected from the public OpenRouter model catalog; replace it if the
# free catalog changes or a better Russian-capable free model is available.
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=poolside/laguna-xs-2.1:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_TITLE=Nornikel-AI-Science-Hack
OPENROUTER_HTTP_REFERER=
OPENROUTER_MAX_TOKENS=3000
OPENROUTER_TEMPERATURE=0
OPENROUTER_TIMEOUT=60
OPENROUTER_MAX_RETRIES=3

# Режим LLM-клиента: mock | real (YandexGPT) | deepseek (DeepSeek-on-Yandex) | openrouter
LLM_CLIENT_MODE=mock

# --- Deep Research агент (agent/deep_research.py, LangGraph) ---
# Суммарный лимит вызовов инструментов (graph_search + rag_search вместе)
# на один запуск агента. Агент останавливается по достижении лимита, даже
# если модель просит продолжить.
DEEP_RESEARCH_MAX_TOOL_CALLS=10
